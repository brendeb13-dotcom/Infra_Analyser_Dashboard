# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/infra_analyzer
DB_ECHO=true

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_LOG_LEVEL=info

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SMTP Configuration
SMTP_SERVER=smtp.company.com
SMTP_PORT=587
SMTP_USER=noreply@company.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_ADDR=noreply@company.com

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# WinRM Configuration
WINRM_PORT=5985
WINRM_SECURE_PORT=5986
WINRM_USERNAME=domain\username
WINRM_PASSWORD=password
WINRM_AUTH_METHOD=kerberos

# SSH Configuration
SSH_KEY_PATH=/path/to/ssh/key
SSH_PORT=22

# Logging
LOG_LEVEL=INFO
LOG_FILE=/logs/app.log

# Features
ENABLE_EMAIL_REPORTS=true
ENABLE_REPORT_EXPORT=true
REPORT_RETENTION_DAYS=30

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
